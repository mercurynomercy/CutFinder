# CutFinder environment configuration (OPTIONAL).
# A .env file is no longer required — these values can be set in the Settings
# UI instead, which persists them to ~/.cutfinder/config.json (shared across
# libraries). The Settings UI is authoritative: anything saved there OVERRIDES
# this file (and any env var), since `make dev` exports .env into the
# environment as the same fallback layer. .env / env vars only fill keys the
# UI hasn't set. Never commit .env — it has secrets.

# OMLX local inference server endpoint (OpenAI-compatible)
OMLX_BASE_URL=http://localhost:8000/v1

# OMLX authentication key
OMLX_API_KEY=your-omlx-key

# Whisper and Demucs models download into the project models/ folder on first
# use (or via `make models`) — no path configuration needed.
