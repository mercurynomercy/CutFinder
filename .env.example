# CutFinder environment configuration.
# Copy this file to .env and fill in the values below.
# Never commit .env — it contains secrets.

# OMLX local inference server endpoint (OpenAI-compatible)
OMLX_BASE_URL=http://localhost:8000/v1

# OMLX authentication key (required)
OMLX_API_KEY=your-omlx-key

# Optional: local directory holding the mlx-whisper model. When set, the model
# is loaded from here (and `make models` downloads into it) instead of the
# HuggingFace cache (~/.cache/huggingface). Leave empty to use the HF cache.
# WHISPER_MODEL_PATH=/AI/Models/ASRs/mlx-community/whisper-large-v3-mlx
