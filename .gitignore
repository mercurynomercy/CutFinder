# 本地测试素材（大文件，不入库）
testVideo/

# 本地模型缓存（Whisper / Demucs，按需联网下载，不入库）
models/

# 密钥/端点不入库（OMLX 配置走设置页 → ~/.cutfinder/config.json；保留忽略以防本地遗留的密钥文件被提交）
.env
.env.local

# Python (uv / venv)
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Node / 前端
node_modules/
frontend/dist/
*.local

# 打包产物（CutFinder.app / .dmg）
/dist/

# 运行时数据（素材库内的数据库与缩略图）
.cutfinder/

# dev server PID file (written by scripts/dev.sh on each run)
.dev-pids

# macOS
.DS_Store

# 编辑器
.idea/
.vscode/

# Build / test artifacts (frontend)
*.tsbuildinfo
playwright-report/
test-results/
.vite/

# Debug scripts (e2e development)
*e2e/_debug*.mjs
test_*.mjs
